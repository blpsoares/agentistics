{
  "title": "Agentistics — Claude Stats",
  "uid": "agentistics-main",
  "timezone": "browser",
  "refresh": "30s",
  "time": { "from": "now-24h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Custo Total (USD)",
      "type": "stat",
      "gridPos": { "x": 0, "y": 0, "w": 4, "h": 4 },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "none" },
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "decimals": 2,
          "color": { "mode": "fixed", "fixedColor": "green" }
        }
      },
      "targets": [{ "datasource": "Prometheus", "expr": "claude_stats_cost_usd_USD_total", "instant": true }]
    },
    {
      "id": 2,
      "title": "Mensagens Totais",
      "type": "stat",
      "gridPos": { "x": 4, "y": 0, "w": 4, "h": 4 },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "none" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "fixed", "fixedColor": "blue" }
        }
      },
      "targets": [{ "datasource": "Prometheus", "expr": "claude_stats_messages_total", "instant": true }]
    },
    {
      "id": 3,
      "title": "Sessões Totais",
      "type": "stat",
      "gridPos": { "x": 8, "y": 0, "w": 4, "h": 4 },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "none" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "fixed", "fixedColor": "purple" }
        }
      },
      "targets": [{ "datasource": "Prometheus", "expr": "claude_stats_sessions_total", "instant": true }]
    },
    {
      "id": 4,
      "title": "Tool Calls Totais",
      "type": "stat",
      "gridPos": { "x": 12, "y": 0, "w": 4, "h": 4 },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "none" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "fixed", "fixedColor": "orange" }
        }
      },
      "targets": [{ "datasource": "Prometheus", "expr": "claude_stats_tool_calls_total", "instant": true }]
    },
    {
      "id": 5,
      "title": "Streak Atual (dias)",
      "type": "stat",
      "gridPos": { "x": 16, "y": 0, "w": 4, "h": 4 },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "none" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "fixed", "fixedColor": "yellow" }
        }
      },
      "targets": [{ "datasource": "Prometheus", "expr": "claude_stats_streak", "instant": true }]
    },
    {
      "id": 6,
      "title": "Projetos Ativos",
      "type": "stat",
      "gridPos": { "x": 20, "y": 0, "w": 4, "h": 4 },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "none" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "fixed", "fixedColor": "teal" }
        }
      },
      "targets": [{ "datasource": "Prometheus", "expr": "claude_stats_active_projects", "instant": true }]
    },
    {
      "id": 7,
      "title": "Tokens Input vs Output",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "options": { "tooltip": { "mode": "multi" } },
      "fieldConfig": {
        "defaults": { "unit": "short" },
        "overrides": [
          { "matcher": { "id": "byName", "options": "Input" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "blue" } }] },
          { "matcher": { "id": "byName", "options": "Output" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "green" } }] }
        ]
      },
      "targets": [
        { "datasource": "Prometheus", "expr": "claude_stats_tokens_input_total", "legendFormat": "Input" },
        { "datasource": "Prometheus", "expr": "claude_stats_tokens_output_total", "legendFormat": "Output" }
      ]
    },
    {
      "id": 8,
      "title": "Tokens por Modelo (Input)",
      "type": "barchart",
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
      "options": { "orientation": "horizontal", "legend": { "displayMode": "list", "placement": "bottom" } },
      "fieldConfig": { "defaults": { "unit": "short" } },
      "targets": [{ "datasource": "Prometheus", "expr": "claude_stats_tokens_by_model_input_total", "instant": true, "legendFormat": "{{model_id}}" }]
    },
    {
      "id": 9,
      "title": "Git — Linhas Adicionadas vs Removidas",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 12, "w": 12, "h": 8 },
      "options": { "tooltip": { "mode": "multi" } },
      "fieldConfig": {
        "defaults": { "unit": "short" },
        "overrides": [
          { "matcher": { "id": "byName", "options": "Adicionadas" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "green" } }] },
          { "matcher": { "id": "byName", "options": "Removidas" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } }] }
        ]
      },
      "targets": [
        { "datasource": "Prometheus", "expr": "claude_stats_git_lines_added_total", "legendFormat": "Adicionadas" },
        { "datasource": "Prometheus", "expr": "claude_stats_git_lines_removed_total", "legendFormat": "Removidas" }
      ]
    },
    {
      "id": 10,
      "title": "Git — Commits e Pushes",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 12, "w": 12, "h": 8 },
      "options": { "tooltip": { "mode": "multi" } },
      "fieldConfig": { "defaults": { "unit": "short" } },
      "targets": [
        { "datasource": "Prometheus", "expr": "claude_stats_git_commits_total", "legendFormat": "Commits" },
        { "datasource": "Prometheus", "expr": "claude_stats_git_pushes_total", "legendFormat": "Pushes" }
      ]
    }
  ],
  "schemaVersion": 39
}
