{
  "name": "agentistics",
  "version": "1.1.1",
  "description": "Local analytics dashboard for AI coding assistants — tracks tokens, cost, sessions, and activity from ~/.claude/",
  "keywords": [
    "claude",
    "claude-code",
    "ai",
    "analytics",
    "dashboard",
    "developer-tools",
    "opentelemetry"
  ],
  "homepage": "https://github.com/blpsoares/agentistics",
  "repository": {
    "type": "git",
    "url": "https://github.com/blpsoares/agentistics.git"
  },
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev:api": "bun run server/index.ts",
    "dev:ui": "vite --logLevel warn",
    "dev": "bun run --bun concurrently \"bun run dev:api\" \"bun run dev:ui\"",
    "build": "vite build",
    "build:assets": "bun run scripts/embed-dist.ts",
    "build:binary": "vite build && bun run scripts/embed-dist.ts && bun build --compile bin/cli.ts --outfile ./release/agentop",
    "preview": "vite preview",
    "watch": "bun run server/otel-watcher.ts",
    "watch:cli": "bun run src/tui/index.ts",
    "stub": "bun run scripts/ensure-type-stub.ts",
    "test": "bun test",
    "prepare": "husky"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@types/bun": "latest",
    "@types/html2canvas": "^1.0.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "husky": "^9.1.7",
    "vite": "^8.0.7"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@inquirer/prompts": "^8.4.1",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/exporter-metrics-otlp-http": "^0.57.2",
    "@opentelemetry/sdk-metrics": "^1.30.1",
    "chokidar": "^5.0.0",
    "date-fns": "^4.1.0",
    "html2canvas": "^1.4.1",
    "jspdf": "^4.2.1",
    "lucide-react": "^1.7.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "recharts": "^3.8.1"
  }
}
