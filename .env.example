# agentistics Team Mode — Docker environment example
# Copy to central.env, fill in the secrets, then run:
#   docker compose --env-file central.env up -d
# Use the name central.env (NOT .env): the central's config must NOT be a
# plain `.env`, because `bun run dev` (a developer's local/member instance)
# auto-loads `.env` from the repo and would wrongly inherit AGENTISTICS_TEAM_CENTRAL=1.
# NEVER commit central.env to version control (it holds the password + secret).

# Host port the dashboard will be available on (default 47291)
APP_PORT=47291

# Bind interface. Default 0.0.0.0 = all interfaces (works out of the box). To restrict
# exposure, set this to a specific IP — e.g. your Tailscale address, which serves only
# tailnet peers over Tailscale's encrypted network.
# BIND_IP=0.0.0.0

# MongoDB — do not change if using the bundled mongo service
MONGO_URL=mongodb://mongo:27017/?replicaSet=rs0
MONGO_DB=agentistics

# Team mode
AGENTISTICS_TEAM_CENTRAL=1
AGENTISTICS_TEAM_ORG=your-org-name

# Auth — generate with: openssl rand -hex 24
AGENTISTICS_TEAM_PASSWORD=CHANGE_ME_strong_random_password

# HMAC session secret — generate with: openssl rand -hex 32
# Keep this separate from the password (a password leak should not enable session forgery)
AGENTISTICS_TEAM_SESSION_SECRET=CHANGE_ME_strong_random_session_secret

# Ingest bearer token (optional; leave empty to allow unauthenticated ingestion)
# Generate with: openssl rand -hex 24
AGENTISTICS_TEAM_INGEST_TOKEN=

# Self-contribution (optional): set this to the central machine's own identity (e.g. your
# email) to ALSO show this machine's local Claude usage in the dashboard — one instance
# acts as both the central AND a contributing member, no separate app needed. When set,
# the app reads the host ~/.claude that docker-compose mounts read-only at /host-claude.
# Leave empty for a dedicated central that only aggregates other members.
AGENTISTICS_CENTRAL_USER=
